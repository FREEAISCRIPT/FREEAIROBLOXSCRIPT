    -- 1. 拖动功能（完全重写）
    local function onDragStart(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            dragStart = input.Position
            dragStartPos = frame.Position
            titleBar.BackgroundColor3 = Color3.fromRGB(50, 40, 70)
        end
    end

    local function onDragMove(input)
        if isDragging then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                dragStartPos.X.Scale,
                dragStartPos.X.Offset + delta.X,
                dragStartPos.Y.Scale,
                dragStartPos.Y.Offset + delta.Y
            )
            frame.Position = newPos
        end
    end

    local function onDragEnd()
        if isDragging then
            isDragging = false
            titleBar.BackgroundColor3 = Color3.fromRGB(30, 20, 45)
        end
    end

    titleBar.InputBegan:Connect(onDragStart)
    titleBar.InputChanged:Connect(onDragMove)
    titleBar.InputEnded:Connect(onDragEnd)

    -- 鼠标离开时停止拖动
    frame.MouseLeave:Connect(function()
        if isDragging then
            isDragging = false
            titleBar.BackgroundColor3 = Color3.fromRGB(30, 20, 45)
        end
    end)

