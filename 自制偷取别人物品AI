            frame.Size = UDim2.new(0, 380, 0, 32)
            contentFrame.Visible = false
            hideBtn.Text = "□"
            hideBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            AddLog("📁 UI已隐藏", Color3.fromRGB(255, 200, 0))
        end
    end)

    -- 3. 暂停功能
    toggleBtn.MouseButton1Click:Connect(function()
        isActive = not isActive
        if isActive then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
